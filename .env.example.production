# =============================================================================
# Outpost Production Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all values before deploying.
# All variables marked REQUIRED must be set. Optional ones can be left empty.

# === Application Version ===
OUTPOST_VERSION="1.0.0"

# === Core URLs (REQUIRED) ===
# The public URL users access the app on (no trailing slash)
MAIN_URL="https://app.example.com"

# The public URL for the frontend (typically same as MAIN_URL)
FRONTEND_URL="https://app.example.com"

# The public backend API URL (used by the frontend to call the API)
NEXT_PUBLIC_BACKEND_URL="https://api.example.com"

# Internal backend URL (used for server-to-server calls within the same network)
BACKEND_INTERNAL_URL="http://backend:3000"

# === Database (REQUIRED) ===
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@db-host:5432/outpost?sslmode=require"

# === Redis (REQUIRED) ===
# Redis connection string (used for caching, queues, and session storage)
REDIS_URL="redis://:password@redis-host:6379"

# === Authentication (REQUIRED) ===
# Secret for signing JWTs — use a long random string (min 32 chars)
JWT_SECRET="generate-a-strong-random-string-at-least-32-chars"

# === AI Service Keys ===
# Anthropic Claude — used for content strategy, outlier analysis, framework diffs
ANTHROPIC_API_KEY=""

# Google Gemini — alternative AI provider
GEMINI_API_KEY=""

# OpenAI — used for post generation and content splitting
OPENAI_API_KEY=""

# fal.ai — used for AI video generation
FAL_KEY=""

# Fish Audio — used for AI voice/audio generation
FISH_AUDIO_KEY=""

# Video model identifier for fal.ai (e.g., "fal-ai/minimax/video-01-live")
VIDEO_MODEL=""

# === Social Platform API Keys ===
# X (Twitter)
X_API_KEY=""
X_API_SECRET=""

# LinkedIn
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# Facebook & Instagram (same app)
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# TikTok
TIKTOK_CLIENT_ID=""
TIKTOK_CLIENT_SECRET=""

# YouTube
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""

# Pinterest
PINTEREST_CLIENT_ID=""
PINTEREST_CLIENT_SECRET=""

# Threads (uses Meta app)
THREADS_APP_ID=""
THREADS_APP_SECRET=""

# Discord
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_BOT_TOKEN_ID=""

# Slack
SLACK_ID=""
SLACK_SECRET=""
SLACK_SIGNING_SECRET=""

# Reddit
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""

# Mastodon
MASTODON_URL="https://mastodon.social"
MASTODON_CLIENT_ID=""
MASTODON_CLIENT_SECRET=""

# === Cloudflare R2 Storage (REQUIRED for production) ===
# Used for storing uploaded media, social media avatars, etc.
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_ACCESS_KEY=""
CLOUDFLARE_SECRET_ACCESS_KEY=""
CLOUDFLARE_BUCKETNAME=""
CLOUDFLARE_BUCKET_URL="https://your-bucket.r2.cloudflarestorage.com/"
CLOUDFLARE_REGION="auto"

# Storage provider — use "cloudflare" in production, "local" for development
STORAGE_PROVIDER="cloudflare"

# === Application Mode (REQUIRED) ===
# Must be "true" for Outpost/Postiz hosted mode
IS_GENERAL="true"

# Set to "true" to disable public registration (invite-only)
DISABLE_REGISTRATION="true"

# Node environment
NODE_ENV="production"

# === Email (Optional but recommended) ===
# Resend API key — enables email activation and notifications
# If not set, users are activated automatically without email verification
#RESEND_API_KEY=""
#EMAIL_FROM_ADDRESS="noreply@example.com"
#EMAIL_FROM_NAME="Outpost"

# === Payments (Optional) ===
# Stripe keys — required if billing is enabled
#STRIPE_PUBLISHABLE_KEY=""
#STRIPE_SECRET_KEY=""
#STRIPE_SIGNING_KEY=""
#STRIPE_SIGNING_KEY_CONNECT=""
#FEE_AMOUNT=0.05

# === Short Link Services (Optional — pick one) ===
#DUB_TOKEN=""
#DUB_API_ENDPOINT="https://api.dub.co"
#DUB_SHORT_LINK_DOMAIN="dub.sh"

# === Chrome Extension (Optional) ===
#EXTENSION_ID=""

# === API Rate Limiting ===
API_LIMIT=30

# === Observability (Optional) ===
# Sentry DSN for error tracking
#SENTRY_DSN=""

# === Build Settings ===
NX_ADD_PLUGINS=false
